# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — Neon (neon.tech) or Supabase recommended
DATABASE_URL="postgresql://user:password@host:5432/the_eye_centre?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Set to your Cloudflare Workers URL (e.g. https://the-eye-centre.<account>.workers.dev)
# or your custom domain once configured
NEXTAUTH_URL="https://your-worker-url.workers.dev"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Get from Stripe Dashboard > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Automatically set when you add a Blob store in the Vercel dashboard,
# or create one manually via the Vercel CLI
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Cloudflare (CI/CD only — set as GitHub secrets, not here) ────────────────
# CLOUDFLARE_API_TOKEN=   # Workers:Edit permission
# CLOUDFLARE_ACCOUNT_ID=  # Found in Cloudflare dashboard > right sidebar
